  "description": "Local infrastructure-as-code provisioner for the Learn to win Discord server.",
  "scripts": {
    "validate": "tsx src/cli.ts validate",
    "plan": "tsx src/cli.ts plan",
    "apply": "tsx src/cli.ts apply",
    "export": "tsx src/cli.ts export",
    "seed:validate": "tsx src/cli.ts seed:validate",
    "seed:plan": "tsx src/cli.ts seed:plan",
    "seed:apply": "tsx src/cli.ts seed:apply",
    "seed:export": "tsx src/cli.ts seed:export",
    "education:validate": "tsx src/cli.ts education:validate",
    "education:plan": "tsx src/cli.ts education:plan",
    "education:run": "tsx src/cli.ts education:run",
    "education:preview": "tsx src/cli.ts education:preview",
    "education:generate-calendar": "tsx src/cli.ts education:generate-calendar",
    "daily-reports:validate": "tsx src/cli.ts daily-reports:validate",
    "daily-reports:run": "tsx src/cli.ts daily-reports:run",
    "generate-stiri-importante": "tsx src/cli.ts generate-stiri-importante",
